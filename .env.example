# Postgres connection string (Vercel Postgres / Neon in production, local Postgres in dev)
POSTGRES_URL=postgres://user:password@localhost:5432/data_room

# Vercel Blob read/write token (from a *public-access* Blob store attached to your Vercel project)
BLOB_READ_WRITE_TOKEN=

# Port for the standalone Express dev server used by `npm run dev:fast` (optional, defaults to 8000)
API_PORT=8000
