{
  "compilerOptions": {
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.api.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "skipLibCheck": true,

    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    // index.ts imports ../server/app, so this project transitively type-checks
    // the whole server/ dependency graph too — it needs the same alias server/
    // itself uses, even though no file directly under api/ imports @shared.
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "include": ["*.ts"]
}
